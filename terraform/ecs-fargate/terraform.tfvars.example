# Copy to terraform.tfvars and adjust. All values have defaults; the ACM cert
# is created and Route 53-validated automatically (no certificate_arn needed).

aws_region  = "us-east-1"
project     = "pharmalink"
environment = "production"
domain      = "mymedcine.com"

# ─── Container images ─────────────────────────────────────────
# Replace the nginx placeholders with your ECR image URIs.
container_images = {
  backend  = "498341975421.dkr.ecr.us-east-1.amazonaws.com/pharmalink-backend:latest"
  frontend = "498341975421.dkr.ecr.us-east-1.amazonaws.com/pharmalink-frontend:latest"
}

# ─── Sizing (optional overrides) ──────────────────────────────
# backend_cpu          = 512
# backend_memory       = 1024
# desired_count        = 2
# docdb_instance_class = "db.t3.medium"
# docdb_instance_count = 2
# redis_num_nodes      = 2
