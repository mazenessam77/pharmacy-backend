# ============================================
# PHARMA APP — Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# --- MongoDB ---
MONGO_USER=admin
MONGO_PASSWORD=your_strong_mongo_password
MONGO_DB=pharma_db

# --- Redis ---
REDIS_PASSWORD=your_strong_redis_password

# --- JWT ---
JWT_ACCESS_SECRET=your_jwt_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars

# --- Cloudinary (Image Upload) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Google Maps (Frontend) ---
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_key

# --- Google OAuth (backend) ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- Google OAuth (frontend — MUST start with NEXT_PUBLIC_) ---
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# --- Email (SMTP) ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@pharmalink.com

# --- Firebase (Push Notifications) ---
FIREBASE_PROJECT_ID=your_project
FIREBASE_PRIVATE_KEY=your_key
FIREBASE_CLIENT_EMAIL=your_email

# --- Google Vision API (optional, alternative to Tesseract) ---
GOOGLE_VISION_API_KEY=your_key
